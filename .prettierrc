{
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "es5",
    "printWidth": 100,
    "htmlWhitespaceSensitivity": "ignore",
    "endOfLine": "lf",
    "plugins": ["prettier-plugin-ejs"],
    "overrides": [
        {
            "files": "*.ejs",
            "options": {
                "parser": "html"
            }
        }
    ]
}
